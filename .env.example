# Cyrene environment variables — EXAMPLE / TEMPLATE.
#
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# The real `.env` is git-ignored and MUST NEVER be committed. Secrets
# (API keys, channel tokens) live ONLY in the environment / `.env` — never in
# `config.toml`. The TOML config references each secret by the VARIABLE NAME
# below (e.g. `api_key_env = "OPENAI_API_KEY"`); Cyrene resolves the value from
# here at runtime. All values below are placeholders, not real credentials.
#
# Cyrene fuses and EXCEEDS the provider/integration coverage of the reference
# agents: every OpenAI-compatible endpoint works through the generic provider
# (set the key here + point `base_url` at it in config.toml), so the list below
# is a curated superset you can pick from — you only need the ones you use.

# =============================================================================
# Model providers — first-class integrations (Requirement 12)
# =============================================================================
# OpenAI (and OpenAI-compatible). https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Optional base URL override for self-hosted / proxy OpenAI-compatible servers.
OPENAI_BASE_URL=

# Anthropic (Claude). https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter — 300+ models behind one key. https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Google Gemini. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here
# Alias some tools expect; either works.
GOOGLE_API_KEY=your-google-ai-studio-key-here
GEMINI_BASE_URL=

# Local Ollama needs no key by default; set a base URL if it is not local.
OLLAMA_BASE_URL=http://localhost:11434
# Ollama Cloud (hosted open models, OpenAI-compatible). https://ollama.com/settings
OLLAMA_API_KEY=your-ollama-cloud-key-here

# Mistral AI. https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-key-here

# =============================================================================
# Model providers — OpenAI-compatible (set key + base_url in config.toml)
# =============================================================================
# DeepSeek. https://platform.deepseek.com/   base_url: https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key-here
# Groq (fast inference). https://console.groq.com/keys  base_url: https://api.groq.com/openai/v1
GROQ_API_KEY=your-groq-key-here
# xAI (Grok). https://x.ai/api   base_url: https://api.x.ai/v1
XAI_API_KEY=your-xai-key-here
# Together AI. https://api.together.xyz/   base_url: https://api.together.xyz/v1
TOGETHER_API_KEY=your-together-key-here
# Fireworks AI. https://fireworks.ai/   base_url: https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=your-fireworks-key-here
# Perplexity (Sonar). https://www.perplexity.ai/   base_url: https://api.perplexity.ai
PERPLEXITY_API_KEY=your-perplexity-key-here
# Cerebras (fast inference). https://cloud.cerebras.ai/   base_url: https://api.cerebras.ai/v1
CEREBRAS_API_KEY=your-cerebras-key-here
# NovitaAI — 90+ models. https://novita.ai/settings/key-management
NOVITA_API_KEY=your-novita-key-here
NOVITA_BASE_URL=https://api.novita.ai/openai/v1
# z.ai / ZhipuAI GLM. https://z.ai   base_url: https://api.z.ai/api/paas/v4
GLM_API_KEY=your-glm-key-here
GLM_BASE_URL=https://api.z.ai/api/paas/v4
# Kimi / Moonshot AI. https://platform.moonshot.ai/
KIMI_API_KEY=your-kimi-key-here
KIMI_BASE_URL=https://api.moonshot.ai/v1
# Arcee AI (Trinity models). https://chat.arcee.ai/
ARCEEAI_API_KEY=your-arcee-key-here
ARCEE_BASE_URL=
# MiniMax. https://www.minimax.io   base_url: https://api.minimax.io/v1
MINIMAX_API_KEY=your-minimax-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Hugging Face Inference Providers (20+ open models, unified endpoint).
# https://huggingface.co/settings/tokens (permission: "Make calls to Inference Providers")
HF_TOKEN=your-huggingface-token-here
# Xiaomi MiMo. https://platform.xiaomimimo.com   base_url: https://api.xiaomimimo.com/v1
XIAOMI_API_KEY=your-xiaomi-key-here
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
# OpenCode Zen (curated, tested models). https://opencode.ai/auth
OPENCODE_ZEN_API_KEY=your-opencode-zen-key-here
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# =============================================================================
# Channels (Requirement 7)
# =============================================================================
# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=000000000:your-telegram-bot-token-here
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# Slack. Bot (xoxb-) and app-level (xapp-) tokens.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here
SLACK_ALLOWED_USERS=

# Discord bot token.
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# WhatsApp (Cloud API).
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id-here
WHATSAPP_VERIFY_TOKEN=your-whatsapp-webhook-verify-token-here

# Email — IMAP (inbound) + SMTP (outbound). For Gmail, use an App Password.
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=your-email-app-password-here

# Signal (signal-cli REST / linked device).
SIGNAL_PHONE_NUMBER=+10000000000
SIGNAL_CLI_REST_URL=http://localhost:8080

# Matrix.
MATRIX_HOMESERVER_URL=https://matrix.example.org
MATRIX_USER_ID=@cyrene:example.org
MATRIX_ACCESS_TOKEN=your-matrix-access-token-here

# Microsoft Teams (Azure Bot registration).
TEAMS_CLIENT_ID=your-azure-app-client-id-here
TEAMS_CLIENT_SECRET=your-azure-client-secret-here
TEAMS_TENANT_ID=common
TEAMS_ALLOWED_USERS=

# Google Chat (Cloud Pub/Sub pull subscription).
GOOGLE_CHAT_PROJECT_ID=your-gcp-project-id-here
GOOGLE_CHAT_SUBSCRIPTION_NAME=projects/your-project/subscriptions/your-sub
GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GOOGLE_CHAT_ALLOWED_USERS=

# =============================================================================
# Tool API keys (Requirement 28) — web search, extraction, media, voice
# =============================================================================
# Exa — AI-native web search and contents. https://exa.ai
EXA_API_KEY=your-exa-key-here
# Parallel — AI-native web search and extract. https://parallel.ai
PARALLEL_API_KEY=your-parallel-key-here
# Firecrawl — web search, extract, and crawl. https://firecrawl.dev/
FIRECRAWL_API_KEY=your-firecrawl-key-here
# Tavily — search API for agents. https://tavily.com/
TAVILY_API_KEY=your-tavily-key-here
# Brave Search API. https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your-brave-search-key-here
# SerpAPI — Google search results. https://serpapi.com/
SERPAPI_API_KEY=your-serpapi-key-here
# FAL.ai — image / media generation. https://fal.ai/
FAL_KEY=your-fal-key-here
# Replicate — model hosting for image/video/audio. https://replicate.com/
REPLICATE_API_TOKEN=your-replicate-token-here
# Stability AI — image generation. https://platform.stability.ai/
STABILITY_API_KEY=your-stability-key-here
# ElevenLabs — text-to-speech voices. https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-key-here
# OpenAI key dedicated to voice (Whisper STT + TTS), kept separate from the LLM key.
VOICE_TOOLS_OPENAI_KEY=sk-your-openai-voice-key-here
# Browserbase — cloud browser automation. https://browserbase.com/
BROWSERBASE_API_KEY=your-browserbase-key-here
BROWSERBASE_PROJECT_ID=your-browserbase-project-id-here
# Honcho — cross-session user modeling. https://app.honcho.dev
HONCHO_API_KEY=your-honcho-key-here

# =============================================================================
# Webhooks / Event listener (Requirement 9) — signing secrets
# =============================================================================
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here
STRIPE_WEBHOOK_SECRET=whsec-your-stripe-webhook-secret-here
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret-here

# =============================================================================
# Dashboard / gateway (Requirements 22.5, 26) — auth
# =============================================================================
# Token/secret required to access the network-exposed dashboard/gateway.
CYRENE_DASHBOARD_TOKEN=choose-a-strong-random-token-here

# =============================================================================
# Skills Hub (Requirement 25)
# =============================================================================
CYRENE_HUB_TOKEN=your-skills-hub-api-token-here
# GitHub token for higher rate limits on skill search/install/publish.
GITHUB_TOKEN=ghp_your-github-token-here
