# Cyrene environment variables — EXAMPLE / TEMPLATE.
#
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# The real `.env` is git-ignored and MUST NEVER be committed. Secrets
# (API keys, channel tokens) live ONLY in the environment / `.env` — never in
# `config.toml`. The TOML config references each secret by the VARIABLE NAME
# below (e.g. `api_key_env = "OPENAI_API_KEY"`); Cyrene resolves the value from
# here at runtime. All values below are placeholders, not real credentials.

# =============================================================================
# Model providers (Requirement 12)
# =============================================================================
# OpenAI (and OpenAI-compatible). https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Optional base URL override for self-hosted / proxy OpenAI-compatible servers.
OPENAI_BASE_URL=

# Anthropic (Claude). https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter. https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Google Gemini. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Generic OpenAI-compatible providers (DeepSeek, xAI/Groq, Together, etc.).
# Set the credential here and point `base_url` at the endpoint in config.toml.
DEEPSEEK_API_KEY=your-deepseek-key-here
GROQ_API_KEY=your-groq-key-here
XAI_API_KEY=your-xai-key-here
TOGETHER_API_KEY=your-together-key-here

# Local Ollama needs no key by default; set a base URL if it is not local.
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Channels (Requirement 7)
# =============================================================================
# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=000000000:your-telegram-bot-token-here

# Slack. Bot (xoxb-) and app-level (xapp-) tokens.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

# Discord bot token.
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# WhatsApp (Cloud API).
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id-here
WHATSAPP_VERIFY_TOKEN=your-whatsapp-webhook-verify-token-here

# Email — IMAP (inbound) + SMTP (outbound). For Gmail, use an App Password.
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=your-email-app-password-here

# Signal (signal-cli REST / linked device).
SIGNAL_PHONE_NUMBER=+10000000000
SIGNAL_CLI_REST_URL=http://localhost:8080

# Matrix.
MATRIX_HOMESERVER_URL=https://matrix.example.org
MATRIX_USER_ID=@cyrene:example.org
MATRIX_ACCESS_TOKEN=your-matrix-access-token-here

# =============================================================================
# Webhooks / Event listener (Requirement 9) — signing secrets
# =============================================================================
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here
STRIPE_WEBHOOK_SECRET=whsec-your-stripe-webhook-secret-here
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret-here

# =============================================================================
# Dashboard / gateway (Requirements 22.5, 26) — auth
# =============================================================================
# Token/secret required to access the network-exposed dashboard/gateway.
CYRENE_DASHBOARD_TOKEN=choose-a-strong-random-token-here

# =============================================================================
# Skills Hub (Requirement 25)
# =============================================================================
CYRENE_HUB_TOKEN=your-skills-hub-api-token-here
