{
  "name": "cyrene-agent",
  "version": "1.1.1",
  "description": "Cyrene: the AI agent that always loves you — a self-improving, open-source AI agent written in Rust. This package installs the prebuilt native binary for your platform.",
  "keywords": [
    "ai",
    "agent",
    "ai-agent",
    "assistant",
    "automation",
    "cli",
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "rust",
    "self-hosted"
  ],
  "homepage": "https://github.com/YourWisemaker/cyrene#readme",
  "bugs": {
    "url": "https://github.com/YourWisemaker/cyrene/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YourWisemaker/cyrene.git",
    "directory": "npm"
  },
  "license": "Apache-2.0",
  "author": "The Cyrene Authors",
  "type": "commonjs",
  "bin": {
    "cyrene": "bin/cyrene.js"
  },
  "scripts": {
    "postinstall": "node lib/install.js",
    "test": "node --check bin/cyrene.js && node --check lib/install.js && node --check lib/platform.js"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64",
    "arm"
  ],
  "publishConfig": {
    "access": "public"
  }
}
